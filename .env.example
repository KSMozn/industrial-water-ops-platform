# Database
DATABASE_URL=postgresql://waterops:waterops@localhost:5432/waterops?schema=public

# API server
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# AI provider: claude | openai | mock
# `mock` runs deterministically with no network calls — used by tests and for local demo.
AI_PROVIDER=mock
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web (Vite)
VITE_API_BASE_URL=http://localhost:4000
